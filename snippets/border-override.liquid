{%- comment -%}
  Renders border override CSS
{%- endcomment -%}
{% if settings.border_style == "all_side" %}
  --border-width: {{ settings.border_width }}px;
{% else %}
  --border-width: {{ settings.border_direction }};
{% endif %}
 --border-style: {{ settings.border }}; --border-color:
rgb(var(--color-border-rgb) / {{ settings.border_opacity | divided_by: 100.0 }}); --border-radius:
{{ settings.border_radius }}px; {% if settings.border_radius > 0 %} overflow: hidden; {% endif %}
