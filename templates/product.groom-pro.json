                "accordion_row_fHK9ip": {
                  "type": "_accordion-row",
                  "settings": {
                    "heading": "Welche Größe braucht mein Hund?",
                    "open_by_default": false,
                    "icon": "none",
                    "width": 20
                  },
                  "blocks": {
                    "text_B6TETP": {
                      "type": "text",
                      "settings": {
                        "text": "<p>Unsere Bürste ist “One Size” und für alle Hunderassen geeignet – vom kleinen Hund bis zum großen Vierbeiner. Sie passt sich der Fellstruktur an und entfernt nur lose Unterwolle, ohne das Deckhaar zu beschädigen.</p>",
                        "width": "100%",
                        "max_width": "normal",
                        "alignment": "left",
                        "type_preset": "rte",
