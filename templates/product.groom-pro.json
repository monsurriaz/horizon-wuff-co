                "accordion_row_RxxabG": {
                  "type": "_accordion-row",
                  "settings": {
                    "heading": "Wie benutze ich die Bürste richtig?",
                    "open_by_default": false,
                    "icon": "none",
                    "width": 20
                  },
                  "blocks": {
                    "text_nn3DNt": {
                      "type": "text",
                      "settings": {
                        "text": "<p>Beginne mit kurzen Zügen in Wuchsrichtung des Fells. Verwende leichte, sanfte Bewegungen und bürste 5–10 Minuten pro Anwendung. Die Bürste entfernt lose Unterwolle mühelos, sodass kein Druck nötig ist.</p>",
                        "width": "100%",
                        "max_width": "normal",
