                  "settings": {
                    "heading": "Ist GroomPro auch für Katzen geeignet?",
                    "open_by_default": true,
                    "icon": "none",
                    "width": 20
                  },
                  "blocks": {
                    "text_Db4JRk": {
                      "type": "text",
                      "settings": {
                        "text": "<p>Ja! Die Bürste funktioniert für alle Felltypen bei Hunden & Katzen. Besonders hilfreich bei Unterwolle und saisonalem Fellwechsel.</p>",
                        "width": "100%",
